# Copy to .env and fill in values.  .env is .gitignored / .dockerignored.

# ── MySQL (used by both api and backend services) ──────────────────────────
MYSQL_ROOT_PASSWORD=changeme
MYSQL_DATABASE=ppa_dun_api
# In docker-compose, MYSQL_HOST=db (the compose service name).
# When running on the host directly, set MYSQL_HOST=127.0.0.1.
MYSQL_HOST=db
MYSQL_PORT=3306

# ── api service ────────────────────────────────────────────────────────────
# Static API key the api service expects on incoming requests (X-API-Key header).
API_KEY=local-dev-key
# Used by api when running outside Docker (otherwise it points at backend container).
LOCAL_API_SERVER_URL=http://localhost:8001

# ── backend service ────────────────────────────────────────────────────────
# OAuth client ID from Google Cloud Console (used for /api/auth/google).
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
